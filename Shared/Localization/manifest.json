{
  "version": 1,
  "baseLocale": "en",
  "fallbackLocale": "en",
  "placeholderStyle": "foundation-format",
  "catalogSchema": "i18n.schema.json",
  "catalogs": [
    {
      "locale": "en",
      "language": "English",
      "nativeName": "English",
      "textDirection": "ltr",
      "file": "en.json"
    },
    {
      "locale": "zh-Hans",
      "language": "Simplified Chinese",
      "nativeName": "简体中文",
      "textDirection": "ltr",
      "file": "zh-Hans.json"
    },
    {
      "locale": "zh-Hant",
      "language": "Traditional Chinese",
      "nativeName": "繁體中文",
      "textDirection": "ltr",
      "file": "zh-Hant.json"
    }
  ],
  "sharedBy": [
    "Twinskaraoke",
    "Twinskaraoke Watch App"
  ],
  "notes": [
    "Catalog values are flat strings for simple Bundle JSON loading.",
    "Formatted strings use Foundation String(format:) placeholders such as %@ and %d.",
    "Keep key sets identical across locale files."
  ]
}
