{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://twinskaraoke.com/schemas/i18n-catalog.schema.json",
  "title": "Twinskaraoke i18n catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "locale",
    "language",
    "nativeName",
    "textDirection",
    "version",
    "strings"
  ],
  "properties": {
    "locale": {
      "type": "string",
      "minLength": 2
    },
    "language": {
      "type": "string",
      "minLength": 2
    },
    "nativeName": {
      "type": "string",
      "minLength": 2
    },
    "textDirection": {
      "type": "string",
      "enum": [
        "ltr",
        "rtl"
      ]
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "strings": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "pattern": "^[a-z][A-Za-z0-9]*(\\.[a-z][A-Za-z0-9]*)+$"
      }
    }
  }
}
